# Cultivating the Fruits - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

# Your Supabase project URL (e.g., https://abcdefghijklmnop.supabase.co)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anon/public key (safe to use in client-side code)
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================================================
# WEB DEPLOYMENT CONFIGURATION
# ============================================================================

# Web application URL (for partner invite links on native apps)
# Development: http://localhost:8081
# Production: https://app.cultivatingthefruits.com
EXPO_PUBLIC_WEB_URL=http://localhost:8081

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable Supabase cloud sync (true/false)
# Set to false to disable cloud features and use local storage only
EXPO_PUBLIC_ENABLE_SUPABASE=true

# Enable web platform (true/false)
# Set to false to disable web routes and force native-only mode
EXPO_PUBLIC_ENABLE_WEB_PLATFORM=true

# Enable partner linking via URLs (web) or codes (native)
EXPO_PUBLIC_ENABLE_PARTNER_SHARING=true

# ============================================================================
# DEVELOPMENT/DEBUGGING
# ============================================================================

# Enable verbose logging (true/false)
EXPO_PUBLIC_DEBUG_MODE=false

# Sync interval for native background sync (milliseconds)
# Default: 300000 (5 minutes)
EXPO_PUBLIC_SYNC_INTERVAL_MS=300000
